PORT=5002
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Security & Auth
JWT_SECRET=your_jwt_secret_here
CLERK_SECRET_KEY=sk_test_... # Get from Clerk Dashboard
CLERK_WEBHOOK_SECRET=whsec_... # Get from Clerk Webhooks Dashboard
CLERK_ORGANIZATION_ID=org_... # Get from Clerk Dashboard

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# External APIs
NEWSDATA_API_KEY=pub_... # Get from newsdata.io

# Logging (optional)
LOG_LEVEL=info # trace, debug, info, warn, error, fatal
