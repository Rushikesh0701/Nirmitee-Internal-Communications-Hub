VITE_CLERK_PUBLISHABLE_KEY=pk_test_... # Get from Clerk Dashboard
VITE_CLERK_REDIRECT_URL=/sso-callback  # Usually /sso-callback
VITE_CLERK_AFTER_SIGN_OUT_URL=/        # Usually /
VITE_API_BASE_URL=http://localhost:5002/api # Backend URL

# Firebase configuration for cloud messaging / notifications
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key # Get from Firebase Console Project Settings > Cloud Messaging > Web configuration
